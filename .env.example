# Veritas (claims-auditor) — environment template.
# Copy to .env and fill in. NEVER commit a real .env. All keys are free-tier capable.

# --- LLM providers ---------------------------------------------------------
# Primary: Anthropic (Claude Haiku/Sonnet, cost-routed by query complexity).
ANTHROPIC_API_KEY=sk-ant-...

# Demo / BYOK path: OpenRouter exposes free-tier models via an OpenAI-compatible API.
# Used in demo-mode and when a visitor brings their own key.
OPENROUTER_API_KEY=sk-or-...

# Hosted ASR fallback (faster-whisper runs locally; Groq is the hosted option).
GROQ_API_KEY=gsk_...

# --- Data ------------------------------------------------------------------
# Postgres + pgvector. The agent connects with a READ-ONLY role in production.
# docker-compose provisions a local instance at this URL.
DATABASE_URL=postgresql://veritas:veritas@localhost:5432/veritas

# --- Runtime knobs (optional) ---------------------------------------------
# Set to 1 to serve cached/canned responses with no external API calls (recruiter demo).
VERITAS_DEMO_MODE=0
